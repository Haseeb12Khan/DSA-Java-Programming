/* Given an integer A, you need to find the count of it's factors. Factor of a number is the number which divides it perfectly leaving no remainder. */

public class Solution {
    public int solve(int A) {
        int count = 0;
        for(int i=1;i<=A;i++) {
            if(A % i == 0) {
                count++;
            }
        }
        return count;
    }
}
