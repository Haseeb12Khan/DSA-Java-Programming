/* Given an array A and an integer B, find the number of occurrences of B in A. */

public class Solution {
    public int solve(int[] A, int B) {
        int occurrence = 0;
        for(int i=0;i<A.length;i++) {
            if(A[i] == B) {
                occurrence++;
            }
        }
        return occurrence;
    }
}
